# Byte-compiled / cache
__pycache__/
*.py[cod]
*.pyc

# Jupyter
.ipynb_checkpoints/

# Virtual environments
venv/
env/
.venv/

# Environment variables / secrets
.env

# Data (raw data can be large / shouldn't live in git history)
data/raw/*
!data/raw/.gitkeep
data/cleaned/*.csv
!data/cleaned/.gitkeep

# SQLite db files (keep schema scripts, not the db itself)
*.db
*.sqlite3

# Tableau packaged workbooks can be large — track .twb, not .twbx, if size is an issue
# dashboards/*.twbx

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
